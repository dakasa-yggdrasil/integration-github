{
  "apiVersion": "yggdrasil.io/v1alpha1",
  "kind": "integration_type",
  "metadata": {
    "name": "github",
    "namespace": "global",
    "description": "Example GitHub integration type for workflow dispatch."
  },
  "spec": {
    "provider": "github",
    "adapter": {
      "transport": "rabbitmq",
      "version": "1.0.0",
      "queues": {
        "describe": "yggdrasil.adapter.github.describe",
        "execute": "yggdrasil.adapter.github.execute"
      },
      "timeout_seconds": 20
    },
    "capabilities": [
      "describe",
      "execute"
    ],
    "credential_schema": {
      "mode": "inline",
      "properties": {
        "token": {
          "type": "string",
          "secret": true
        }
      }
    },
    "instance_schema": {
      "mode": "inline",
      "properties": {
        "default_owner": {
          "type": "string"
        },
        "default_ref": {
          "type": "string",
          "default": "main"
        },
        "default_workflow": {
          "type": "string"
        },
        "api_base_url": {
          "type": "string",
          "default": "https://api.github.com"
        }
      }
    },
    "resource_types": [
      {
        "name": "repository",
        "canonical_prefix": "thirdparty.github.repository",
        "identity_template": "repository.{repository}",
        "discoverable": false,
        "default_actions": [
          "dispatch_workflow"
        ]
      }
    ],
    "action_catalog": [
      {
        "name": "dispatch_workflow",
        "description": "Dispatch a GitHub Actions workflow run.",
        "resource_types": [
          "repository"
        ]
      }
    ],
    "discovery": {
      "mode": "push",
      "cursor": "none"
    },
    "normalization": {
      "external_id_path": "full_name",
      "name_path": "name",
      "owner_path": "owner.login",
      "fallback_resource_prefix": "thirdparty.github.custom"
    },
    "execution": {
      "supports_dry_run": false
    },
    "extensions": {}
  }
}
